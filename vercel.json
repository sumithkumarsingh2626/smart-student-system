{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "public": true,
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**/*.{js,ts}": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
